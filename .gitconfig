[color]
    diff = auto
    status = auto
    branch = auto
[core]
    editor = vim
    excludesfile = ~/.gitignore_global
[user]
	name = Praveen Srinivasan
	email = praveen.srinivasan@zip.co
[credential]
    helper = osxkeychain
[push]
    default = simple
[init]
    defaultBranch = main
[pull]
    rebase = false
[alias]
    hist = log --oneline --graph --decorate

[core]
    pager = delta

[interactive]
    diffFilter = delta --color-only

[delta]
    navigate = true    # use n and N to move between diff sections
    side-by-side = true


    # delta detects terminal colors automatically; set one of these to disable auto-detection
    # dark = true
    # light = true

[merge]
    conflictstyle = diff3

[diff]
    colorMoved = default
